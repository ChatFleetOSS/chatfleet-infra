JWT_SECRET=
MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=
MONGO_APP_PASSWORD=
OPENAI_API_KEY=
# The installer/upgrader writes an explicit deployment channel and tags.
# Default channel is `stable`; `edge` tracks the latest snapshots built from `main`.
CHATFLEET_CHANNEL=
API_TAG=
WEB_TAG=
# Explicit Mongo URI (password must be URL-encoded if it contains special characters)
# The installer will populate this automatically.
MONGO_URI=
SSE_HEARTBEAT_MS=15000
TOP_K_DEFAULT=6
TEMPERATURE_DEFAULT=0.2
MAX_UPLOAD_MB=50
CHAT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
